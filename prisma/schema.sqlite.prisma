// Habakkuk Pharmacy — SQLite Schema (Desktop/Offline Mode)
// Enums are NOT supported in SQLite via Prisma — we use String with comments for valid values
// This schema mirrors schema.prisma (PostgreSQL) but uses SQLite-compatible types

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-sqlite"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  username           String?   @unique
  password           String
  name               String
  role               String    @default("STAFF")       // CEO | ADMIN | STAFF
  permissions        String    @default("")            // comma-separated Permission values
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(true)
  twoFactorEnabled   Boolean   @default(false)
  twoFactorEmail     String?
  twoFactorCode      String?
  twoFactorExpiry    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          String?

  transactions       Transaction[]
  orders             Order[]
  claimedOrders      Order[]         @relation("ClaimedOrders")
  auditLogs          AuditLog[]
  notifications      Notification[]
  transactionEdits   TransactionEdit[] @relation("TransactionEdits")

  @@map("users")
}

model Settings {
  id                String   @id @default(cuid())
  pharmacyName      String
  location          String
  contact           String
  email             String
  logo              String?
  footerText        String?
  receiptHeader     String?
  receiptFooter     String?
  taxRate           Float    @default(0)
  currency          String   @default("UGX")
  lowStockThreshold Int      @default(10)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("settings")
}

model Product {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  category           String
  sku                String   @unique
  barcode            String?
  price              Float
  costPrice          Float
  quantity           Int      @default(0)
  reorderLevel       Int      @default(10)
  unitOfMeasure      String   @default("Unit")
  expiryDate         DateTime?
  manufacturer       String?
  batchNumber        String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  stockAdjustments   StockAdjustment[]
  orderItems         OrderItem[]
  transactionItems   TransactionItem[]
  purchaseOrderItems PurchaseOrderItem[]
  packages           ProductPackage[]
  batches            ProductBatch[]

  @@map("products")
}

model ProductPackage {
  id              String   @id @default(cuid())
  productId       String
  name            String
  unitsPerPackage Int
  price           Float
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
  @@map("product_packages")
}

model ProductBatch {
  id              String   @id @default(cuid())
  productId       String
  batchNumber     String
  quantity        Int
  initialQuantity Int
  expiryDate      DateTime
  receivedDate    DateTime @default(now())
  costPrice       Float
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  transactionItems TransactionItem[]

  @@unique([productId, batchNumber])
  @@map("product_batches")
}

model StockAdjustment {
  id          String   @id @default(cuid())
  productId   String
  quantity    Int
  type        String   // INCREASE | DECREASE | CORRECTION
  reason      String?
  previousQty Int
  newQty      Int
  createdAt   DateTime @default(now())
  createdBy   String

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("stock_adjustments")
}

model Transaction {
  id             String   @id @default(cuid())
  transactionNo  String   @unique
  customerId     String?
  clientName     String?
  clientPhone    String?
  clientAddress  String?
  userId         String
  totalAmount    Float
  discount       Float    @default(0)
  tax            Float    @default(0)
  netAmount      Float
  paymentMethod  String   // CASH | CARD | MOBILE_MONEY | BANK_TRANSFER
  status         String   @default("COMPLETED") // PENDING | COMPLETED | CANCELLED | REFUNDED
  notes          String?
  isEdited       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User      @relation(fields: [userId], references: [id])
  customer       Customer? @relation(fields: [customerId], references: [id])
  items          TransactionItem[]
  edits          TransactionEdit[]

  @@map("transactions")
}

model TransactionItem {
  id              String   @id @default(cuid())
  transactionId   String
  productId       String
  batchId         String?
  quantity        Int
  unitPrice       Float
  costPrice       Float?
  totalPrice      Float
  packageName     String?
  packageQuantity Int?

  transaction     Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])
  batch           ProductBatch? @relation(fields: [batchId], references: [id])

  @@map("transaction_items")
}

model Customer {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String?
  name        String
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders       Order[]
  transactions Transaction[]

  @@map("customers")
}

model Supplier {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String?
  address       String?
  contactPerson String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  orderNo      String   @unique
  supplierId   String
  totalAmount  Float
  status       String   @default("DRAFT") // DRAFT | SENT | CONFIRMED | SHIPPED | RECEIVED | CANCELLED
  notes        String?
  expectedDate DateTime?
  createdBy    String
  emailSent    Boolean  @default(false)
  emailSentAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplier     Supplier          @relation(fields: [supplierId], references: [id])
  items        PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  productId       String?
  productName     String
  quantity        Int
  unitPrice       Float
  totalPrice      Float

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product?      @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

model Order {
  id              String   @id @default(cuid())
  orderNo         String   @unique
  customerId      String?
  orderType       String   @default("CUSTOMER") // CUSTOMER | SUPPLIER
  totalAmount     Float
  status          String   @default("PENDING")  // PENDING | PROCESSING | READY | COMPLETED | CANCELLED
  paymentStatus   String   @default("UNPAID")   // UNPAID | PARTIAL | PAID
  notes           String?
  deliveryAddress String?
  processedBy     String?
  claimedBy       String?
  claimedAt       DateTime?
  isOnlineOrder   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer        Customer? @relation(fields: [customerId], references: [id])
  processedByUser User?     @relation(fields: [processedBy], references: [id])
  claimedByUser   User?     @relation("ClaimedOrders", fields: [claimedBy], references: [id])
  items           OrderItem[]

  @@map("orders")
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Inquiry {
  id            String   @id @default(cuid())
  userId        String?
  userEmail     String
  userName      String
  type          String   // FEATURE_REQUEST | PASSWORD_RESET | ACCESS_REQUEST | DELETE_REQUEST | OTHER
  subject       String
  message       String
  status        String   @default("PENDING") // PENDING | RESOLVED | REJECTED
  adminResponse String?
  respondedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("inquiries")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // NEW_ORDER | ORDER_CLAIMED | ORDER_STATUS | SYSTEM | TRANSACTION_EDIT
  title     String
  message   String
  relatedId String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model TransactionEdit {
  id            String   @id @default(cuid())
  transactionId String
  editedBy      String
  reason        String
  previousData  String
  newData       String
  createdAt     DateTime @default(now())

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  editor        User        @relation("TransactionEdits", fields: [editedBy], references: [id])

  @@map("transaction_edits")
}

model SyncQueue {
  id         String   @id @default(cuid())
  action     String   // CREATE | UPDATE | DELETE
  entityType String
  entityId   String
  payload    String
  status     String   @default("PENDING") // PENDING | PROCESSING | SYNCED | ERROR
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("sync_queue")
}

model SyncLog {
  id         String   @id @default(cuid())
  lastSyncAt DateTime @default(now())
  status     String   // SUCCESS | ERROR
  details    String?

  @@map("sync_logs")
}
