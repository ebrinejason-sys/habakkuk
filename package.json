{
  "name": "habakkuk-pharmacy-pos",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma generate && prisma db push && tsx prisma/seed.ts",
    "setup": "npm install && npm run db:setup",
    "db:desktop:setup": "node scripts/use-sqlite-schema.js && prisma generate && prisma db push --accept-data-loss && tsx prisma/seed.desktop.ts",
    "db:desktop:reset": "node scripts/use-sqlite-schema.js && prisma db push --force-reset && tsx prisma/seed.desktop.ts",
    "sync:initial": "tsx scripts/initial-sync.ts",
    "desktop:dev": "concurrently --kill-others \"cross-env PORT=3001 NEXT_PUBLIC_IS_DESKTOP=true DATABASE_URL=file:./dev.db next dev\" \"wait-on http://localhost:3001 && electron .\"",
    "desktop:build": "cross-env NEXT_PUBLIC_IS_DESKTOP=true DATABASE_URL=file:./dev.db next build && electron-builder",
    "desktop": "electron .",
    "build:desktop": "next build && electron-builder"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "autoprefixer": "^10.4.23",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.460.0",
    "next": "^16.1.1",
    "next-auth": "^4.24.11",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "resend": "^4.0.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "postcss": "^8.5.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wait-on": "^9.0.4",
    "xlsx": "^0.18.5"
  }
}